# ---------------------------------------------------------------------------
# Crowdfunding dApp — frontend configuration (Stellar testnet)
# Copy this file to `.env.local`. All values below are PUBLIC (NEXT_PUBLIC_*),
# safe to ship to the browser, and already match the deployed testnet contract.
# ---------------------------------------------------------------------------

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase (testnet)
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed crowdfunding contract id
NEXT_PUBLIC_CONTRACT_ID=CAM3ICMZ5IIANPDDIM3BJMBSQAO2MYYXJOZCFVVKCBMSZNXVQRULBZJC

# Token accepted by the campaign (native XLM Stellar Asset Contract on testnet)
NEXT_PUBLIC_TOKEN_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
NEXT_PUBLIC_TOKEN_SYMBOL=XLM
NEXT_PUBLIC_TOKEN_DECIMALS=7

# stellar.expert explorer base (for transaction / contract links)
NEXT_PUBLIC_EXPLORER_BASE=https://stellar.expert/explorer/testnet
